generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ==========================================
// ENUMS
// ==========================================

enum Role {
  OWNER
  ADMIN
  MEMBER
}

enum InvitationStatus {
  PENDING
  ACCEPTED
  REJECTED
  EXPIRED
}

enum ExpenseSplitType {
  EQUAL
  PERCENTAGE
  EXACT
  SHARES
  ADJUSTMENT
}

enum PaymentStatus {
  PENDING
  COMPLETED
  FAILED
  REFUNDED
}

enum SubscriptionTier {
  FREE
  PRO
  PREMIUM
}

enum NotificationType {
  EXPENSE_ADDED
  PAYMENT_RECEIVED
  CHORE_ASSIGNED
  BILL_DUE
  SYSTEM_ALERT
}

// ==========================================
// MODELS
// ==========================================

model User {
  id              String    @id @default(uuid())
  clerkUserId     String    @unique
  email           String    @unique
  firstName       String?
  lastName        String?
  profileImageUrl String?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  deletedAt       DateTime?

  // Relationships
  memberships         ApartmentMember[]
  invitationsSent     Invitation[]      @relation("SentInvitations")
  invitationsReceived Invitation[]      @relation("ReceivedInvitations")
  expensesPaid        Expense[]         @relation("ExpensePayer")
  expenseSplits       ExpenseSplit[]
  paymentsSent        Payment[]         @relation("PaymentSender")
  paymentsReceived    Payment[]         @relation("PaymentReceiver")
  settlements         Settlement[]      @relation("SettlementUser")
  notifications       Notification[]
  activityLogs        ActivityLog[]
  chores              Chore[]
  reminders           Reminder[]
  supportTickets      Support[]
  auditLogs           AuditLog[]
  subscription        Subscription?

  @@index([email])
  @@index([clerkUserId])
}

model Apartment {
  id          String    @id @default(uuid())
  name        String
  description String?
  currency    String    @default("USD")
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  deletedAt   DateTime?

  // Relationships
  members        ApartmentMember[]
  invitations    Invitation[]
  expenses       Expense[]
  settlements    Settlement[]
  bills          Bill[]
  recurringBills RecurringBill[]
  categories     Category[]
  activityLogs   ActivityLog[]
  chores         Chore[]
  auditLogs      AuditLog[]
}

model ApartmentMember {
  id          String    @id @default(uuid())
  userId      String
  apartmentId String
  role        Role      @default(MEMBER)
  joinedAt    DateTime  @default(now())
  leftAt      DateTime?

  user      User      @relation(fields: [userId], references: [id])
  apartment Apartment @relation(fields: [apartmentId], references: [id])

  @@unique([userId, apartmentId])
  @@index([apartmentId])
}

model Invitation {
  id            String           @id @default(uuid())
  apartmentId   String
  senderId      String
  receiverId    String?
  receiverEmail String
  token         String           @unique
  status        InvitationStatus @default(PENDING)
  expiresAt     DateTime
  createdAt     DateTime         @default(now())
  updatedAt     DateTime         @updatedAt

  apartment Apartment @relation(fields: [apartmentId], references: [id])
  sender    User      @relation("SentInvitations", fields: [senderId], references: [id])
  receiver  User?     @relation("ReceivedInvitations", fields: [receiverId], references: [id])

  @@index([receiverEmail])
  @@index([token])
}

model Expense {
  id          String           @id @default(uuid())
  apartmentId String
  payerId     String
  categoryId  String?
  title       String
  description String?
  amount      Decimal          @db.Decimal(10, 2)
  currency    String           @default("USD")
  date        DateTime
  splitType   ExpenseSplitType @default(EQUAL)
  receiptUrl  String?
  tags            String[]
  isRecurring     Boolean          @default(false)
  recurringInterval String?
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
  deletedAt       DateTime?

  apartment Apartment      @relation(fields: [apartmentId], references: [id])
  payer     User           @relation("ExpensePayer", fields: [payerId], references: [id])
  category  Category?      @relation(fields: [categoryId], references: [id])
  splits    ExpenseSplit[]
  receipt   Receipt?

  @@index([apartmentId])
  @@index([payerId])
  @@index([date])
}

model ExpenseSplit {
  id         String   @id @default(uuid())
  expenseId  String
  userId     String
  amount     Decimal  @db.Decimal(10, 2)
  percentage Decimal? @db.Decimal(5, 2)
  shares     Int?
  isSettled  Boolean  @default(false)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  expense Expense @relation(fields: [expenseId], references: [id], onDelete: Cascade)
  user    User    @relation(fields: [userId], references: [id])

  @@unique([expenseId, userId])
  @@index([userId])
}

model Payment {
  id         String        @id @default(uuid())
  senderId   String
  receiverId String
  amount     Decimal       @db.Decimal(10, 2)
  currency   String        @default("USD")
  status     PaymentStatus @default(COMPLETED)
  method     String? // e.g., Stripe, Venmo, Cash
  reference  String?
  notes      String?
  createdAt  DateTime      @default(now())
  updatedAt  DateTime      @updatedAt
  deletedAt  DateTime?

  sender   User @relation("PaymentSender", fields: [senderId], references: [id])
  receiver User @relation("PaymentReceiver", fields: [receiverId], references: [id])

  @@index([senderId, receiverId])
}

model Settlement {
  id           String   @id @default(uuid())
  apartmentId  String
  userId       String
  balance      Decimal  @db.Decimal(10, 2) // Positive means user is owed, Negative means user owes
  calculatedAt DateTime @default(now())

  apartment Apartment @relation(fields: [apartmentId], references: [id])
  user      User      @relation("SettlementUser", fields: [userId], references: [id])

  @@index([apartmentId, userId])
}

model Receipt {
  id              String   @id @default(uuid())
  expenseId       String   @unique
  url             String
  extractedData   Json?
  confidenceScore Decimal? @db.Decimal(5, 2)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  expense Expense @relation(fields: [expenseId], references: [id], onDelete: Cascade)
}

model Category {
  id          String   @id @default(uuid())
  apartmentId String
  name        String
  icon        String?
  color       String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  apartment Apartment @relation(fields: [apartmentId], references: [id])
  expenses  Expense[]

  @@unique([apartmentId, name])
}

model Bill {
  id              String    @id @default(uuid())
  apartmentId     String
  title           String
  amount          Decimal   @db.Decimal(10, 2)
  dueDate         DateTime
  isPaid          Boolean   @default(false)
  recurringBillId String?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  deletedAt       DateTime?

  apartment     Apartment      @relation(fields: [apartmentId], references: [id])
  recurringBill RecurringBill? @relation(fields: [recurringBillId], references: [id])

  @@index([apartmentId])
  @@index([dueDate])
}

model RecurringBill {
  id          String   @id @default(uuid())
  apartmentId String
  title       String
  amount      Decimal  @db.Decimal(10, 2)
  frequency   String // e.g., MONTHLY, WEEKLY
  nextDueDate DateTime
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  apartment Apartment @relation(fields: [apartmentId], references: [id])
  bills     Bill[]

  @@index([apartmentId])
}

model Chore {
  id          String    @id @default(uuid())
  apartmentId String
  assigneeId  String
  title       String
  description String?
  dueDate     DateTime
  isCompleted Boolean   @default(false)
  completedAt DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  deletedAt   DateTime?

  apartment Apartment @relation(fields: [apartmentId], references: [id])
  assignee  User      @relation(fields: [assigneeId], references: [id])

  @@index([apartmentId])
  @@index([assigneeId])
}

model Notification {
  id        String           @id @default(uuid())
  userId    String
  type      NotificationType
  title     String
  body      String
  isRead    Boolean          @default(false)
  actionUrl String?
  createdAt DateTime         @default(now())

  user User @relation(fields: [userId], references: [id])

  @@index([userId, isRead])
}

model Reminder {
  id        String   @id @default(uuid())
  userId    String
  title     String
  triggerAt DateTime
  isSent    Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id])

  @@index([userId])
  @@index([triggerAt])
}

model Subscription {
  id                   String           @id @default(uuid())
  userId               String           @unique
  tier                 SubscriptionTier @default(FREE)
  stripeCustomerId     String?          @unique
  stripeSubscriptionId String?          @unique
  status               String?
  currentPeriodEnd     DateTime?
  createdAt            DateTime         @default(now())
  updatedAt            DateTime         @updatedAt

  user User @relation(fields: [userId], references: [id])
}

model ActivityLog {
  id          String   @id @default(uuid())
  apartmentId String
  userId      String
  action      String
  entityType  String
  entityId    String
  details     Json?
  createdAt   DateTime @default(now())

  apartment Apartment @relation(fields: [apartmentId], references: [id])
  user      User      @relation(fields: [userId], references: [id])

  @@index([apartmentId])
}

model Support {
  id        String   @id @default(uuid())
  userId    String
  subject   String
  message   String
  status    String   @default("OPEN")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id])
}

model AuditLog {
  id          String   @id @default(uuid())
  userId      String?
  apartmentId String?
  action      String
  ipAddress   String?
  userAgent   String?
  details     Json?
  createdAt   DateTime @default(now())

  user      User?      @relation(fields: [userId], references: [id])
  apartment Apartment? @relation(fields: [apartmentId], references: [id])
}
